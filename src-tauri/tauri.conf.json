{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "PUBG Desktop",
  "version": "0.1.0",
  "identifier": "com.tauri.dev",
  "build": {
    "frontendDist": "../.next",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "PUBG Desktop",
        "width": 460,
        "height": 340,
        "minWidth": 460,
        "minHeight": 340,
        "resizable": false,
        "maximizable": false,
        "minimizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false,
        "alwaysOnTop": true,
        "theme": "Dark",
        "backgroundColor": "#09090b",
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
